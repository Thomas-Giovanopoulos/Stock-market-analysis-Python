@article{HommUlrich2012BtSr,
abstract = {► We use the Aumann-Serrano index to introduce an new performance measure. ► The new performance measure respects stochastic dominance. ► If returns are close to normal the ranking is close to Sharpe ratio ranking. ► We provide parametric and non-parametric estimation techniques. ► We illustrate our measure using mutual and hedge funds data.
We propose a performance measure that generalizes the Sharpe ratio. The new performance measure is monotone with respect to stochastic dominance and consistently accounts for mean, variance and higher moments of the return distribution. It is equivalent to the Sharpe ratio if returns are normally distributed. Moreover, the two performance measures are asymptotically equivalent as the underlying distributions converge to the normal distribution. We suggest a parametric and a non-parametric estimator for the new performance measure and provide an empirical illustration using mutual funds and hedge funds data.},
author = {Homm, Ulrich and Pigorsch, Christian},
address = {Amsterdam},
copyright = {2012 Elsevier B.V.},
issn = {0378-4266},
journal = {Journal of Banking and Finance},
keywords = {Empirical Research ;  Evaluation ;  Gaussian distribution ;  Indexes ;  Measurement ;  Mutual funds ;  Parameter estimation ;  Rate of return},
language = {eng},
number = {8},
pages = {2274-2284},
publisher = {Elsevier B.V},
title = {Beyond the Sharpe ratio: An application of the Aumann-Serrano index to performance measurement},
volume = {36},
year = {2012},
}

